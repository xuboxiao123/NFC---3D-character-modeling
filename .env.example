# ============================================================
#  Docker Compose 环境变量模板
#  用法：cp .env.example .env  然后填入真实值
#  ⚠️ .env 已被 .gitignore 忽略，不会被提交
# ============================================================

# ============ MySQL ============
# root 用户密码（会自动作为 backend 连接密码）
DB_PASSWORD=nfc_secure_pass_2026

# ============ 豆包 Doubao（图生图，必填才能用 AI 生成） ============
# 申请地址：https://console.volcengine.com/ark/
DOUBAO_API_KEY=
DOUBAO_MODEL=ep-20260329195113-47fgd
DOUBAO_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations

# ============ 腾讯混元 Hunyuan 3D（3D 模型生成，必填才能用 3D） ============
# 申请地址：https://cloud.tencent.com/product/hunyuan3d
HUNYUAN_API_KEY=
HUNYUAN_SUBMIT_URL=https://api.ai3d.cloud.tencent.com/v1/ai3d/submit
HUNYUAN_QUERY_URL=https://api.ai3d.cloud.tencent.com/v1/ai3d/query

# ============ Cloudflare R2 图床（图片永久存储，可选） ============
# 申请地址：https://dash.cloudflare.com/ → R2
# 若留空，系统仍可运行，但 AI 生成的图片只保留临时 URL（可能失效）
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=capstone
R2_PUBLIC_DOMAIN=